set_global_assignment -name IP_GENERATED_DEVICE_FAMILY "{MAX 10}"
set_global_assignment -name VERILOG_FILE [file join $::quartus(qip_path) "zvibe_osc.v"]
set_global_assignment -name VERILOG_FILE [file join $::quartus(qip_path) "../simulation/int_osc.v"]
set_global_assignment -name VERILOG_FILE [file join $::quartus(qip_path) "../simulation/submodules/altera_int_osc.v"]
set_global_assignment -name SDC_FILE [file join $::quartus(qip_path) "../simulation/submodules/altera_int_osc.sdc"]
