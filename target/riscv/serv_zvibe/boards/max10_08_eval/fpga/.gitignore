# UFM IP Generated Files (regenerate with ./generate_ufm_ip.sh)
# These are machine-generated and should not be in git
ip/*/synthesis/
ip/*/simulation/
ip/*/*.csv
ip/*/*.html
ip/*/*.bsf
ip/*/*.cmp
ip/*/*.spd
ip/*/*.sip
ip/*/*_bb.v
ip/*/*_inst.v
ip/*/*_inst.vhd
ip/*/*_generation.rpt
ufm/*/synthesis/
ufm/*/simulation/
ufm_old/

# Keep these files
!ip/**/*.qip
!ip/**/*.sip
!*.tcl
!*.sdc
!debug.stp

# .qpf and .qsf are generated by build.tcl (project_new -overwrite)
# and deleted by make clean — do not track them

# IP system info files (generated by Quartus)
*.sopcinfo
ip/*/*.xml
*.xml

# Quartus Conversion Files — generated at runtime by update_ufm_pof.py
# Contain absolute paths from the build machine; regenerate with: make program-complete
*.cof
