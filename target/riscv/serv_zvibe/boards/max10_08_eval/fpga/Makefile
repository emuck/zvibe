# Makefile for Servant ZVibe FPGA Build (MAX10 08 Evaluation Board)

DESIGN = servant_zvibe_max10_08_eval_xip
BUILD_DIR = build
QUARTUS = quartus_sh
QUARTUS_PGM = quartus_pgm
# qsys-generate is typically in QSYS_ROOTDIR or can be called via quartus_sh
QSYS_GENERATE = $(shell which qsys-generate 2>/dev/null || echo "qsys-generate")
BOARD = max10_08_eval

# Paths
COMMON_SW = ../../../common/sw
SW_DIR    = ../sw

# Game to embed in flash image (passed through to sw/Makefile)
# restaurant.z3 ships with repo; override with GAME=czech for the test-suite build
GAME ?= restaurant

# Firmware binaries
BOOT_STUB = $(COMMON_SW)/flash_boot_banner.hex
UFM_BIN = $(SW_DIR)/max10_flash_test.bin
UFM_HEX = ufm_data.hex

# RTL source files (using wildcard for proper dependency tracking)
BOARD_RTL = $(wildcard ../rtl/*.v)
COMMON_RTL_V = $(wildcard ../../../common/rtl/*.v)
COMMON_RTL_SV = $(wildcard ../../../common/rtl/*.sv)
UFM_RTL = $(wildcard ../../../common/rtl/ufm/*.v)
SERV_RTL = $(wildcard ../../../serv/rtl/*.v)
SERV_SERVILE = $(wildcard ../../../serv/servile/*.v)

# All RTL dependencies
RTL_SOURCES = $(BOARD_RTL) $(COMMON_RTL_V) $(COMMON_RTL_SV) $(UFM_RTL) $(SERV_RTL) $(SERV_SERVILE)

# Constraint files
CONSTRAINTS = max10_08_eval.sdc

# All dependencies for bitstream build (XIP doesn't need boot stub)
BITSTREAM_DEPS = build.tcl $(RTL_SOURCES) $(CONSTRAINTS)

# IP core output files (generated by make generate-ip)
UFM_QIP = ip/ufm/synthesis/ufm.qip
OSC_QIP = ip/zvibe_osc/synthesis/zvibe_osc.qip

# uart-echo-xip test variables
XIP_ECHO_BIN = $(COMMON_SW)/uart_echo_xip.bin
XIP_ECHO_COF = uart_echo_xip.cof
XIP_ECHO_HEX = uart_echo_xip_ufm.hex
XIP_ECHO_POF = uart_echo_xip.pof
XIP_ECHO_OFFSET = 0x100

# ufm-write-test variables
UFM_WRITE_TEST_BIN = $(COMMON_SW)/test_ufm_write.bin
UFM_WRITE_TEST_COF = ufm_write_test.cof
UFM_WRITE_TEST_HEX = ufm_write_test_ufm.hex
UFM_WRITE_TEST_POF = ufm_write_test.pof
UFM_WRITE_TEST_OFFSET = 0x100

.PHONY: all build clean generate-ip program program-flash program-flash-ufm program-pof-gui generate-pof-with-ufm ufm-hex reports help show-deps check-quartus program-complete program-complete-quiet uart-echo-xip uart-echo-xip-build uart-echo-xip-program ufm-write-test ufm-write-test-build ufm-write-test-program

all: build

# Generate IP cores (one-time setup — run before first build)
generate-ip:
	@echo "Generating UFM IP core..."
	@if [ -f generate_ufm_ip.sh ]; then \
		bash generate_ufm_ip.sh; \
	else \
		echo "ERROR: generate_ufm_ip.sh not found"; \
		exit 1; \
	fi

# Check if Quartus is available
check-quartus:
	@if ! which $(QUARTUS) > /dev/null 2>&1; then \
		echo ""; \
		echo "ERROR: Quartus Prime not found in PATH."; \
		echo ""; \
		echo "Please ensure Quartus Prime is installed and added to your PATH."; \
		echo "If you just added Quartus to ~/.bashrc, try:"; \
		echo "  source ~/.bashrc"; \
		echo ""; \
		echo "Or set PATH manually:"; \
		echo "  export PATH=\$$PATH:/path/to/quartus/bin"; \
		echo ""; \
		exit 1; \
	fi
	@echo "Quartus found: $$($(QUARTUS) --version 2>&1 | head -1)"

# Generate UFM IP core if missing (auto-triggered by build dependency)
$(UFM_QIP):
	@echo "UFM IP core not found — generating now..."
	@bash generate_ufm_ip.sh

# Build bitstream (IP cores built automatically as dependencies)
build: $(BUILD_DIR)/$(DESIGN).pof

$(BUILD_DIR)/$(DESIGN).pof: $(BITSTREAM_DEPS) $(UFM_QIP)
	@echo "=========================================="
	@echo "Starting Quartus Build..."
	@echo "=========================================="
	@echo "Dependencies changed:"
	@echo "  RTL files: $(words $(RTL_SOURCES)) files"
	@echo "  Constraints: $(words $(CONSTRAINTS)) files"
	@echo "  Boot stub: $(BOOT_STUB)"
	@echo "=========================================="
	@mkdir -p $(BUILD_DIR)
	$(QUARTUS) -t build.tcl
	@cp output_files/$(DESIGN).pof $(BUILD_DIR)/
	@cp output_files/$(DESIGN).sof $(BUILD_DIR)/
	@echo ""
	@echo "=========================================="
	@echo "Build Complete!"
	@echo "Bitstream: $(BUILD_DIR)/$(DESIGN).pof (for flash)"
	@echo "SRAM: $(BUILD_DIR)/$(DESIGN).sof (for SRAM)"
	@echo "=========================================="

# Show all dependencies (useful for debugging)
show-deps:
	@echo "=========================================="
	@echo "FPGA Build Dependencies"
	@echo "=========================================="
	@echo "Board RTL ($(words $(BOARD_RTL)) files):"
	@$(foreach f,$(BOARD_RTL),echo "  $(f)";)
	@echo ""
	@echo "Common RTL Verilog ($(words $(COMMON_RTL_V)) files):"
	@$(foreach f,$(COMMON_RTL_V),echo "  $(f)";)
	@echo ""
	@echo "Common RTL SystemVerilog ($(words $(COMMON_RTL_SV)) files):"
	@$(foreach f,$(COMMON_RTL_SV),echo "  $(f)";)
	@echo ""
	@echo "UFM RTL ($(words $(UFM_RTL)) files):"
	@$(foreach f,$(UFM_RTL),echo "  $(f)";)
	@echo ""
	@echo "SERV CPU RTL ($(words $(SERV_RTL)) files):"
	@$(foreach f,$(SERV_RTL),echo "  $(f)";)
	@echo ""
	@echo "SERV Servile ($(words $(SERV_SERVILE)) files):"
	@$(foreach f,$(SERV_SERVILE),echo "  $(f)";)
	@echo ""
	@echo "Constraints ($(words $(CONSTRAINTS)) files):"
	@$(foreach f,$(CONSTRAINTS),echo "  $(f)";)
	@echo ""
	@echo "Boot stub: $(BOOT_STUB)"
	@echo "=========================================="

# Show reports
reports:
	@echo "\n=========================================="
	@echo "Utilization (Post-Synthesis)"
	@echo "=========================================="
	@cat output_files/$(DESIGN).fit.summary 2>/dev/null | grep -A 20 "Logic utilization" || echo "Report not found. Run 'make build' first."
	@echo "\n=========================================="
	@echo "Timing Summary"
	@echo "=========================================="
	@cat output_files/$(DESIGN).sta.summary 2>/dev/null || echo "Report not found. Run 'make build' first."

# Program FPGA SRAM (temporary - lost on power cycle)
program: $(BUILD_DIR)/$(DESIGN).sof
	@echo "=========================================="
	@echo "Programming MAX10 FPGA SRAM..."
	@echo "=========================================="
	@echo "WARNING: This programs SRAM only (lost on power cycle)"
	@echo "Use 'make program-flash' for persistent programming"
	@echo ""
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;$(BUILD_DIR)/$(DESIGN).sof@1"
	@echo ""
	@echo "Programming complete!"

# Program Flash (persistent)
program-flash: output_files/$(DESIGN).pof
	@echo "=========================================="
	@echo "Programming MAX10 Flash..."
	@echo "=========================================="
	@echo "This programs the flash memory (persistent across power cycles)"
	@echo ""
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;output_files/$(DESIGN).pof@1"
	@echo ""
	@echo "Flash programming complete!"

# Program Complete (CFM + UFM) - Automated Workflow
program-complete: output_files/$(DESIGN).sof
	@echo "=========================================="
	@echo "Complete Programming (CFM + UFM)"
	@echo "=========================================="
	@echo ""
	@echo "Building firmware and flash image (GAME=$(GAME))..."
	@$(MAKE) -C $(SW_DIR) flash-test GAME=$(GAME)
	@echo ""
	@echo "Step 1: Converting flash image to Intel HEX..."
	@python3 bin_to_hex.py $(SW_DIR)/max10_flash_test.bin ufm_data.hex
	@echo ""
	@echo "Step 2: Generating .pof with quartus_cpf..."
	@python3 -c "\
import sys; sys.path.insert(0, '.'); \
from update_ufm_pof import create_cof_file; \
from pathlib import Path; \
d = Path('.').resolve(); \
create_cof_file(d/'build/$(DESIGN).sof', d/'ufm_data.hex', d/'pof_gen_zvibe.cof', d/'zvibe.pof')" && \
	quartus_cpf -c pof_gen_zvibe.cof
	@echo "  Generated: zvibe.pof"
	@echo ""
	@echo "Step 3: Detecting USB-Blaster..."
	@PGMR=$$($(QUARTUS_PGM) --list 2>&1 | grep -o "USB-Blaster[^ ]*" | head -1); \
	if [ -z "$$PGMR" ]; then \
		echo "ERROR: No USB-Blaster detected"; \
		echo "Connect USB-Blaster and try again"; \
		exit 1; \
	fi; \
	echo "  Found: $$PGMR"; \
	echo ""; \
	echo "Step 4: Programming .pof (CFM + UFM)..."; \
	$(QUARTUS_PGM) -c "$$PGMR" -m jtag -o "P;zvibe.pof" > /tmp/pgm_pof.log 2>&1; \
	rc=$$?; \
	grep -E "(Error:|succeeded)" /tmp/pgm_pof.log | tail -3; \
	if [ $$rc -ne 0 ] || grep -q "Error:" /tmp/pgm_pof.log; then \
		cat /tmp/pgm_pof.log; \
		echo "ERROR: .pof programming failed (exit=$$rc)"; \
		exit 1; \
	fi; \
	echo ""; \
	echo "Step 5: Programming .sof (SRAM) for clean reset..."; \
	$(QUARTUS_PGM) -c "$$PGMR" -m jtag -o "P;output_files/$(DESIGN).sof" > /tmp/pgm_sof.log 2>&1; \
	rc=$$?; \
	grep -E "(Error:|succeeded)" /tmp/pgm_sof.log | tail -3; \
	if [ $$rc -ne 0 ] || grep -q "Error:" /tmp/pgm_sof.log; then \
		cat /tmp/pgm_sof.log; \
		echo "ERROR: .sof programming failed (exit=$$rc)"; \
		exit 1; \
	fi
	@echo ""
	@echo "=========================================="
	@echo "Programming Complete!"
	@echo "=========================================="
	@echo "Hardware is programmed with:"
	@echo "  - FPGA bitstream (CFM)"
	@echo "  - Firmware + Game (UFM)"
	@echo ""
	@echo "Next steps:"
	@echo "  1. Press reset button on board (or power cycle)"
	@echo "  2. Connect UART: picocom -b 115200 /dev/ttyUSB0"
	@echo "  3. Game should auto-launch"
	@echo "=========================================="

# Quiet version for automated testing (minimal output)
program-complete-quiet: output_files/$(DESIGN).sof
	@$(MAKE) -C $(SW_DIR) flash-test GAME=$(GAME) > /dev/null
	@python3 bin_to_hex.py $(SW_DIR)/max10_flash_test.bin ufm_data.hex > /dev/null
	@python3 -c "\
import sys; sys.path.insert(0, '.'); \
from update_ufm_pof import create_cof_file; \
from pathlib import Path; \
d = Path('.').resolve(); \
create_cof_file(d/'build/$(DESIGN).sof', d/'ufm_data.hex', d/'pof_gen_zvibe.cof', d/'zvibe.pof')" > /dev/null && \
	quartus_cpf -c pof_gen_zvibe.cof > /dev/null 2>&1
	@PGMR=$$($(QUARTUS_PGM) --list 2>&1 | grep -o "USB-Blaster[^ ]*" | head -1); \
	if [ -z "$$PGMR" ]; then \
		echo "ERROR: No USB-Blaster detected"; \
		exit 1; \
	fi; \
	printf "  Programming .pof (CFM+UFM)... "; \
	$(QUARTUS_PGM) -c "$$PGMR" -m jtag -o "P;zvibe.pof" > /tmp/pgm_pof.log 2>&1; \
	rc=$$?; \
	if [ $$rc -ne 0 ] || grep -q "Error:" /tmp/pgm_pof.log; then \
		echo "✗"; \
		cat /tmp/pgm_pof.log; \
		echo "ERROR: .pof programming failed (exit=$$rc)"; \
		exit 1; \
	fi; \
	echo "✓"; \
	printf "  Programming .sof (SRAM)... "; \
	$(QUARTUS_PGM) -c "$$PGMR" -m jtag -o "P;output_files/$(DESIGN).sof" > /tmp/pgm_sof.log 2>&1; \
	rc=$$?; \
	if [ $$rc -ne 0 ] || grep -q "Error:" /tmp/pgm_sof.log; then \
		echo "✗"; \
		cat /tmp/pgm_sof.log; \
		echo "ERROR: .sof programming failed (exit=$$rc)"; \
		exit 1; \
	fi; \
	echo "✓"

# UART Echo XIP Test - one-command build + program
uart-echo-xip: uart-echo-xip-build uart-echo-xip-program

uart-echo-xip-build: $(XIP_ECHO_BIN) $(BUILD_DIR)/$(DESIGN).sof
	@echo "=========================================="
	@echo "Building UART Echo XIP Test Image..."
	@echo "=========================================="
	python3 bin_to_hex.py --start-address $(XIP_ECHO_OFFSET) $(XIP_ECHO_BIN) $(XIP_ECHO_HEX)
	quartus_cpf -c $(XIP_ECHO_COF)
	@echo "✓ POF ready: $(XIP_ECHO_POF)"

uart-echo-xip-program: $(XIP_ECHO_POF)
	@echo "Programming UART Echo XIP Test..."
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;$(XIP_ECHO_POF)@1"

$(XIP_ECHO_BIN):
	$(MAKE) -C $(COMMON_SW) uart_echo_xip.bin

# UFM write test targets (BOOT → ERASE → ERASE OK → WRITE → VERIFY → PASS)
ufm-write-test: ufm-write-test-build ufm-write-test-program

ufm-write-test-build: $(UFM_WRITE_TEST_BIN) $(BUILD_DIR)/$(DESIGN).sof
	@echo "=========================================="
	@echo "Building UFM Write Test Image..."
	@echo "=========================================="
	python3 bin_to_hex.py --start-address $(UFM_WRITE_TEST_OFFSET) $(UFM_WRITE_TEST_BIN) $(UFM_WRITE_TEST_HEX)
	quartus_cpf -c $(UFM_WRITE_TEST_COF)
	@echo "✓ POF ready: $(UFM_WRITE_TEST_POF)"

ufm-write-test-program: $(UFM_WRITE_TEST_POF)
	@echo "Programming UFM Write Test..."
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;$(UFM_WRITE_TEST_POF)@1"

$(UFM_WRITE_TEST_BIN):
	$(MAKE) -C $(COMMON_SW) test_ufm_write.bin

# Convert UFM binary to Intel Hex format
$(UFM_HEX): $(UFM_BIN) bin_to_hex.py
	@echo "=========================================="
	@echo "Converting UFM binary to Intel Hex..."
	@echo "=========================================="
	@if [ ! -f $(UFM_BIN) ]; then \
		echo "ERROR: UFM binary not found: $(UFM_BIN)"; \
		echo "Build firmware first: cd $(COMMON_SW) && make max10-flash-test"; \
		exit 1; \
	fi
	python3 bin_to_hex.py $(UFM_BIN) $(UFM_HEX)
	@ls -lh $(UFM_HEX)

ufm-hex: $(UFM_HEX)

# Program CFM and UFM separately (two-step process)
# This is more reliable than trying to generate a combined .pof via command line
program-flash-ufm: output_files/$(DESIGN).pof $(UFM_HEX)
	@echo "=========================================="
	@echo "Programming MAX10 Flash (CFM + UFM)..."
	@echo "=========================================="
	@echo "Step 1: Programming CFM (FPGA Configuration)..."
	@echo ""
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;output_files/$(DESIGN).pof@1"
	@echo ""
	@echo "Step 2: Programming UFM (Application Data)..."
	@echo ""
	@# For MAX10, we need to use the GUI or a .cof file to program UFM
	@# The command line doesn't support UFM programming directly
	@echo "=========================================="
	@echo "ERROR: UFM programming via command line is not supported"
	@echo "=========================================="
	@echo ""
	@echo "You must use the Quartus Programmer GUI to program UFM:"
	@echo ""
	@echo "Method 1: Generate combined .pof with GUI (Recommended)"
	@echo "  1. File → Convert Programming Files"
	@echo "  2. Set output: .pof, Internal Configuration"
	@echo "  3. Add SOF: output_files/$(DESIGN).sof"
	@echo "  4. Add UFM: $(UFM_HEX) at address 0x00000"
	@echo "  5. Click Generate"
	@echo "  6. Program the generated .pof file"
	@echo ""
	@echo "Method 2: Program UFM separately (if CFM already programmed)"
	@echo "  1. Start Quartus Programmer"
	@echo "  2. Add File → $(UFM_HEX)"
	@echo "  3. Set to program UFM region"
	@echo "  4. Click Start"
	@echo ""
	@echo "See PROGRAMMING_QUICK_START.md for detailed GUI instructions"
	@echo "=========================================="
	@false

# Generate combined .pof with UFM using GUI (helper to show instructions)
generate-pof-with-ufm: $(UFM_HEX)
	@echo "=========================================="
	@echo "Generate .pof with UFM Data (GUI Method)"
	@echo "=========================================="
	@echo ""
	@echo "Quartus Lite does not support scripted UFM programming."
	@echo "Use the Quartus GUI to generate a combined .pof file:"
	@echo ""
	@echo "1. Start Quartus Prime"
	@echo "2. File → Convert Programming Files"
	@echo ""
	@echo "3. Configure Output:"
	@echo "   Programming file type: Programmer Object File (.pof)"
	@echo "   Mode: Internal Configuration"
	@echo "   File name: output_files/$(DESIGN)_with_ufm.pof"
	@echo ""
	@echo "4. Click 'Options/Boot Info':"
	@echo "   Power on Reset: Fast POR Delay"
	@echo "   Disable all security options"
	@echo ""
	@echo "5. Add Input Files:"
	@echo "   Click 'Add File' → output_files/$(DESIGN).sof"
	@echo ""
	@echo "6. Add UFM Data:"
	@echo "   Under 'User Flash Memory', click 'Add...'"
	@echo "   File: $(UFM_HEX)"
	@echo "   Start Address: 0x00000"
	@echo "   End Address: Auto"
	@echo ""
	@echo "7. Generate:"
	@echo "   Check 'Create Memory Map File'"
	@echo "   Click 'Generate'"
	@echo ""
	@echo "8. Program:"
	@echo "   make program-pof-gui"
	@echo ""
	@echo "See PROGRAMMING_QUICK_START.md for screenshots and details"
	@echo "=========================================="

# Program a .pof file generated via GUI
program-pof-gui:
	@if [ ! -f output_files/$(DESIGN)_with_ufm.pof ]; then \
		echo "ERROR: output_files/$(DESIGN)_with_ufm.pof not found"; \
		echo "Generate it first using: make generate-pof-with-ufm"; \
		exit 1; \
	fi
	@echo "=========================================="
	@echo "Programming output_files/$(DESIGN)_with_ufm.pof..."
	@echo "=========================================="
	$(QUARTUS_PGM) -c 1 -m jtag -o "p;output_files/$(DESIGN)_with_ufm.pof@1"
	@echo ""
	@echo "=========================================="
	@echo "Programming complete!"
	@echo "=========================================="
	@echo "Next steps:"
	@echo "  1. Power cycle the board"
	@echo "  2. Connect UART: picocom -b 115200 /dev/ttyUSB1"
	@echo "  3. You should see boot banner and game launch"
	@echo "=========================================="

# Clean build artifacts
clean:
	rm -rf $(BUILD_DIR)
	rm -rf output_files
	rm -rf db
	rm -rf incremental_db
	rm -rf .qsys_edit
	rm -f *.qpf
	rm -f *.qsf
	rm -f *.qws
	rm -f flash_boot_banner.hex
	rm -f $(UFM_HEX)
	rm -f convert_ufm.cof
	rm -f cclk_init_high.vol
	rm -f *.rpt
	rm -f *.summary
	rm -f *.done
	rm -f *.jdi
	rm -f *.pin

