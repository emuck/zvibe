	@echo "  build                  - Build bitstream"
	@echo "  program                - Program FPGA SRAM (temporary - no UFM)"
	@echo "  program-flash          - Program CFM only (persistent - no UFM)"
	@echo "  program-complete       - Program CFM + UFM (automated, recommended)"
	@echo "  ufm-hex                - Convert UFM binary to Intel Hex"
	@echo "  generate-pof-with-ufm  - Show instructions for GUI .pof generation"
	@echo "  program-pof-gui        - Program .pof generated via GUI"
	@echo "  reports                - Show utilization and timing reports"
	@echo "  show-deps              - List all RTL dependencies"
	@echo "  clean                  - Remove build artifacts"
	@echo "  help                   - Show this help"
	@echo ""
	@echo "Recommended Workflow (Fully Automated):"
	@echo "  1. Build firmware:    make program-complete GAME=<id>  (rebuilds automatically)"
	@echo "  2. Build FPGA:        make build"
	@echo "  3. Program device:    make program-complete"
	@echo "  4. Reset board and connect UART: picocom -b 115200 /dev/ttyUSB0"
	@echo ""
	@echo "Alternative Programming Workflows:"
	@echo "  GUI Workflow:         make generate-pof-with-ufm → program-pof-gui"
	@echo ""
	@echo "Quick Test (No UFM - FPGA logic only):"
	@echo "  make program          - Programs SRAM (temporary)"
	@echo ""
	@echo "How It Works (program-complete):"
	@echo "  1. Converts flash binary to Intel HEX format"
	@echo "  2. Generates .pof with UFM data via quartus_cpf"
	@echo "  3. Auto-detects USB-Blaster programmer"
	@echo "  4. Programs both CFM (bitstream) and UFM (firmware+game)"
	@echo "  5. Programs SRAM for immediate clean reset"
	@echo ""
	@echo "IP Cores:"
	@echo "  UFM and Oscillator are generated by 'make generate-ip' from .qsys files."
	@echo "  PLL is instantiated directly in the top-level RTL (no separate IP files)."
	@echo "  To update IP cores:"
	@echo "    - UFM:        ip/ufm/ufm.qsys"
	@echo "    - Oscillator: ip/zvibe_osc/zvibe_osc.qsys"
	@echo "    - PLL:        Edit defparam block in rtl/servant_zvibe_max10_08_eval_xip.sv"
	@echo ""
	@echo "Build directory: $(BUILD_DIR)"
	@echo "See PROGRAMMING_QUICK_START.md for detailed instructions"
	@echo ""
