##
## Quartus Build Script for Servant ZVibe on MAX10 08 Evaluation Board
##

set design_name "servant_zvibe_max10_08_eval_xip"
set part "10M08SAE144C8GES"
set build_dir "build"

## Create project
project_new -overwrite $design_name

## Set project properties
set_global_assignment -name FAMILY "MAX 10"
set_global_assignment -name DEVICE $part
set_global_assignment -name TOP_LEVEL_ENTITY $design_name


catch {set_global_assignment -name NUM_PARALLEL_PROCESSORS [exec nproc]}

set_global_assignment -name ORIGINAL_QUARTUS_VERSION 25.1
set_global_assignment -name LAST_QUARTUS_VERSION "25.1.0 Standard Edition"
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name MIN_CORE_JUNCTION_TEMP 0
set_global_assignment -name MAX_CORE_JUNCTION_TEMP 85
set_global_assignment -name ERROR_CHECK_FREQUENCY_DIVISOR 1
# Note: MAX10 08 uses internal voltage regulator, no external core voltage setting needed
# NOMINAL_CORE_SUPPLY_VOLTAGE removed - let Quartus determine correct voltage for device

## Device Configuration
# UFM requires Single Compressed Image configuration mode
set_global_assignment -name INTERNAL_FLASH_UPDATE_MODE "SINGLE COMP IMAGE"

## Path configuration
# Common RTL (shared across boards)
set common_rtl "../../../common/rtl"
# Board-specific RTL
set board_rtl "../rtl"
# SERV submodule paths
set serv_dir "../../../../serv/rtl"
set serv_servile "../../../../serv/servile"
set serv_servant "../../../../serv/servant"
# Common software (for hex files)
set common_sw "../../../common/sw"
# UFM IP core (will be generated by user)
set ufm_ip_dir "ip/ufm"

## No hex files needed for XIP (CPU boots from UFM)

## Add RTL sources

# FPGA Top level (board-specific)
set_global_assignment -name SYSTEMVERILOG_FILE $board_rtl/servant_zvibe_max10_08_eval_xip.sv

# Bootloader FSM not needed for XIP (removed)

# UFM Controllers (common)
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/ufm/max10_ufm_unified.sv

# Servant ZVibe SoC (common)
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/servant_zvibe.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/servant_zvibe_mux.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/servant_mem_mux.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/servant_ram.sv
set_global_assignment -name VERILOG_FILE $serv_servant/servant_timer.v

# UART (common - SystemVerilog)
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/uart/uart_wb.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/uart/uart_tx.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/uart/uart_rx.sv
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/uart/fifo_sync.sv

# GPIO Debug LEDs (common)
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/gpio_leds.sv

# QSPI Flash Mimic (for MAX10 - no external QSPI flash)
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/qspi/wb_ram_flash_mimic.sv

# Multi-core wrapper (from SERV submodule, except servile_mux which is modified)
set_global_assignment -name VERILOG_FILE $serv_servile/servile.v
set_global_assignment -name SYSTEMVERILOG_FILE $common_rtl/servile_mux.sv
set_global_assignment -name VERILOG_FILE $serv_servile/servile_arbiter.v

# SERV CPU Core (from submodule)
set_global_assignment -name VERILOG_FILE $serv_dir/serv_top.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_state.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_decode.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_ctrl.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_alu.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_rf_top.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_rf_if.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_rf_ram.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_rf_ram_if.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_mem_if.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_csr.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_immdec.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_aligner.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_bufreg.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_bufreg2.v
set_global_assignment -name VERILOG_FILE $serv_dir/serv_compdec.v

## Add UFM IP Core (committed to repo)
set ufm_qip "ip/ufm/synthesis/ufm.qip"
if {[file exists $ufm_qip]} {
    set_global_assignment -name QIP_FILE $ufm_qip
    puts "Added UFM IP core: $ufm_qip"
} else {
    puts "ERROR: UFM IP core not found: $ufm_qip"
    puts "  This file should be committed to the repo"
    exit 1
}

## Add constraints
set_global_assignment -name SDC_FILE max10_08_eval.sdc

## Pin assignments for MAX10 08 Evaluation Board
# External 50 MHz clock (CLK0p on Bank 2)
set_location_assignment PIN_27 -to clk_50mhz
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to clk_50mhz

# DIP Switch 1 - PLL async reset (normally OFF)
set_location_assignment PIN_124 -to dip_sw1
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to dip_sw1

# UART (CP2102 USB-to-UART module)
set_location_assignment PIN_70 -to uart_rxd     ;# RXD: FPGA input from CP2102
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to uart_rxd
set_location_assignment PIN_69 -to uart_txd     ;# TXD: FPGA output to CP2102
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to uart_txd

# GPIO LEDs (5 LEDs - active low on this board)
set_location_assignment PIN_132 -to gpio_led[0]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to gpio_led[0]
set_location_assignment PIN_134 -to gpio_led[1]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to gpio_led[1]
set_location_assignment PIN_135 -to gpio_led[2]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to gpio_led[2]
set_location_assignment PIN_140 -to gpio_led[3]
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to gpio_led[3]
set_location_assignment PIN_141 -to gpio_led[4]  ;# Heartbeat LED
set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to gpio_led[4]

## Compilation settings
set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top

## Synthesis settings
set_global_assignment -name OPTIMIZATION_MODE "HIGH PERFORMANCE EFFORT"
set_global_assignment -name AUTO_SHIFT_REGISTER_RECOGNITION AUTO
set_global_assignment -name AUTO_RAM_RECOGNITION ON
set_global_assignment -name AUTO_ROM_RECOGNITION ON

## Fitter settings - High effort for timing closure
set_global_assignment -name FITTER_EFFORT "STANDARD FIT"
set_global_assignment -name PHYSICAL_SYNTHESIS_COMBO_LOGIC ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_DUPLICATION ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_RETIMING ON
set_global_assignment -name PHYSICAL_SYNTHESIS_EFFORT EXTRA
set_global_assignment -name PHYSICAL_SYNTHESIS_ASYNCHRONOUS_SIGNAL_PIPELINING ON

## Timing settings
set_global_assignment -name TIMEQUEST_MULTICORNER_ANALYSIS ON
set_global_assignment -name TIMEQUEST_DO_REPORT_TIMING ON

## SignalTap Logic Analyzer
set_global_assignment -name ENABLE_SIGNALTAP ON
set_global_assignment -name USE_SIGNALTAP_FILE debug.stp
set_global_assignment -name SIGNALTAP_FILE debug.stp
puts "SignalTap Logic Analyzer enabled (debug.stp)"

## Compile
puts "\n=========================================="
puts "Starting Quartus Compilation..."
puts "=========================================="

load_package flow
execute_flow -compile

puts "\n=========================================="
puts "Compilation Complete!"
puts "=========================================="
puts "Bitstream: output_files/$design_name.pof (for flash)"
puts "SRAM: output_files/$design_name.sof (for SRAM)"
puts "=========================================="

project_close
