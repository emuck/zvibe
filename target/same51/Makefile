# SAM E51 Curiosity Nano - zvibe Z-Machine with SmartEEPROM Save/Restore
# Clean production build following project conventions

# Project configuration
PROJECT_NAME = same51_zvibe
MCU_TARGET = ATSAME51J20A
EDBG_TARGET = same51

# Story file configuration (single-game mode)
STORY_FILE ?= ../../games/catalog/czech.z3

# Build mode detection - check for multi-game setup
# Multi-game mode is detected by presence of game_registry.c (generated by unified build system)
GAME_REGISTRY = src/game_registry.c
# Force single-game mode when STORY_FILE is explicitly specified
ifeq ($(origin STORY_FILE),command line)
    MULTI_GAME_MODE := no
else
    MULTI_GAME_MODE := $(shell test -f $(GAME_REGISTRY) && echo yes || echo no)
endif

# OS detection and toolchain configuration
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
    XC32_BASE = /Applications/microchip/xc32
    # XC32_VERSION can be overridden: make XC32_VERSION=v4.6
    ifeq ($(XC32_VERSION),)
        XC32_VERSION := $(shell ls -d $(XC32_BASE)/v* 2>/dev/null | sort -V | tail -1 | xargs basename)
    endif
    ifeq ($(XC32_VERSION),)
        $(error XC32 compiler not found in $(XC32_BASE))
    endif
    XC32_PATH = $(XC32_BASE)/$(XC32_VERSION)/bin
    MCHP_PACKS_BASE = $(HOME)/.mchp_packs/Microchip
else ifeq ($(UNAME_S),Linux)
    XC32_BASE = /opt/microchip/xc32
    # XC32_VERSION can be overridden: make XC32_VERSION=v4.6
    ifeq ($(XC32_VERSION),)
        XC32_VERSION := $(shell ls -d $(XC32_BASE)/v* 2>/dev/null | sort -V | tail -1 | xargs basename)
    endif
    ifeq ($(XC32_VERSION),)
        $(error XC32 compiler not found in $(XC32_BASE))
    endif
    XC32_PATH = $(XC32_BASE)/$(XC32_VERSION)/bin
    MCHP_PACKS_BASE = $(HOME)/.mchp_packs/Microchip
else
    $(error Unsupported operating system: $(UNAME_S))
endif

# DFP (Device Family Pack) detection for XC32 v5.00+
# XC32 v5.00 requires -mdfp flag to locate device support files
XC32_MAJOR := $(shell echo $(XC32_VERSION) | sed 's/v\([0-9]*\).*/\1/')
XC32_NEEDS_DFP := $(shell test $(XC32_MAJOR) -ge 5 2>/dev/null && echo yes || echo no)

ifeq ($(XC32_NEEDS_DFP),yes)
    # Auto-detect latest SAME51_DFP version
    DFP_BASE = $(MCHP_PACKS_BASE)/SAME51_DFP
    DFP_VERSION := $(shell ls -d $(DFP_BASE)/* 2>/dev/null | sort -V | tail -1 | xargs basename)
    ifeq ($(DFP_VERSION),)
        $(error SAME51_DFP not found in $(MCHP_PACKS_BASE). Install via MPLAB X or mchp-packs-cli)
    endif
    DFP_PATH = $(DFP_BASE)/$(DFP_VERSION)
    DFP_FLAG = -mdfp="$(DFP_PATH)"
else
    DFP_FLAG =
endif

# XC32 v4.60 on Linux corrupts temp file paths when TMPDIR is unset
export TMPDIR ?= /tmp

# Toolchain
CC = $(XC32_PATH)/xc32-gcc
OBJCOPY = $(XC32_PATH)/xc32-objcopy
SIZE = $(XC32_PATH)/xc32-size

# Programmer: edbg (cross-platform, macOS and Linux)
# Build from source: https://github.com/ataradov/edbg  (see README for macOS setup)
# On macOS: clone, run make, copy edbg binary to /usr/local/bin
PROGRAMMER = edbg -b -t $(EDBG_TARGET) -c 1000 -p -f
PROG_FILE_EXT = bin

# Directories - following top-level project structure
SRC_DIR = src
BUILD_DIR = build
OBJ_DIR = $(BUILD_DIR)/obj
BIN_DIR = $(BUILD_DIR)/bin

# Compiler flags - optimized for production
CFLAGS = -x c -c -mprocessor=$(MCU_TARGET) $(DFP_FLAG)
CFLAGS += -ffunction-sections -fdata-sections -O2 -fno-common
CFLAGS += -Wall -MP -MMD
CFLAGS += -I"$(SRC_DIR)" -I"include"
CFLAGS += -I"packs/ATSAME51J20A_DFP" -I"packs/CMSIS/" -I"packs/CMSIS/CMSIS/Core/Include"
# zvibe integration for embedded build:
# keep save/restore, but compile out host file I/O and status-line code.
CFLAGS += -I"$(ZVIBE_ROOT)/include" -I"$(ZVIBE_ROOT)/src"
CFLAGS += -DZVIBE_FREESTANDING=1 -DZVIBE_ENABLE_FILE_IO=0 -DZVIBE_ENABLE_STATUS_LINE=0 -DZVIBE_ENABLE_SAVE_RESTORE=1

# Linker flags
LDFLAGS = -mprocessor=$(MCU_TARGET) $(DFP_FLAG) -mno-device-startup-code
LDFLAGS += -Wl,--defsym=__MPLAB_BUILD=1
LDFLAGS += -Wl,--defsym=_min_heap_size=512
LDFLAGS += -Wl,--gc-sections
LDFLAGS += -T startup/ATSAME51J20A.ld

# Source files - conditional based on build mode
ifeq ($(MULTI_GAME_MODE),yes)
    # Multi-game mode - use multi version and game registry
    # Game data sources will be determined after they're generated
    LOCAL_SOURCES = $(SRC_DIR)/zvibe_same51_multi.c \
                    $(SRC_DIR)/game_registry.c \
                    $(SRC_DIR)/save_delta.c \
                    startup/startup_xc32.c \
                    $(SRC_DIR)/clock.c \
                    $(SRC_DIR)/gpio.c \
                    $(SRC_DIR)/timer.c \
                    $(SRC_DIR)/dma.c \
                    $(SRC_DIR)/system.c \
                    $(SRC_DIR)/flash.c \
                    $(SRC_DIR)/uart.c
else
    # Single-game mode - original configuration
    LOCAL_SOURCES = $(SRC_DIR)/zvibe_same51.c \
                    $(SRC_DIR)/story_data.c \
                    startup/startup_xc32.c \
                    $(SRC_DIR)/clock.c \
                    $(SRC_DIR)/gpio.c \
                    $(SRC_DIR)/timer.c \
                    $(SRC_DIR)/dma.c \
                    $(SRC_DIR)/system.c \
                    $(SRC_DIR)/flash.c \
                    $(SRC_DIR)/uart.c
endif

# zvibe core sources
ZVIBE_ROOT = ../..
ZVIBE_CORE_DIR = $(ZVIBE_ROOT)/src
ZVIBE_CORE_SOURCES = $(wildcard $(ZVIBE_CORE_DIR)/core/*.c) \
                     $(ZVIBE_CORE_DIR)/api/zvibe_api.c \
                     $(ZVIBE_CORE_DIR)/api/zvibe_api_file.c

# Object files - all in build/obj directory
LOCAL_OBJECTS = $(patsubst %.c,$(OBJ_DIR)/%.o,$(LOCAL_SOURCES))
ZVIBE_OBJECTS = $(patsubst $(ZVIBE_CORE_DIR)/%.c,$(OBJ_DIR)/zvibe/%.o,$(ZVIBE_CORE_SOURCES))

# Base objects for all builds
OBJECTS = $(LOCAL_OBJECTS) $(ZVIBE_OBJECTS)

# Target binary
TARGET = $(BIN_DIR)/$(PROJECT_NAME).bin

# Default target - conditional based on build mode
ifeq ($(MULTI_GAME_MODE),yes)
all: platform_info directories multi_game_data $(TARGET)
else
all: platform_info directories story_data $(TARGET)
endif

# Show platform information
platform_info:
	@echo "Building on $(UNAME_S) - using XC32 $(XC32_VERSION) at $(XC32_PATH)"
ifeq ($(XC32_NEEDS_DFP),yes)
	@echo "DFP: SAME51_DFP $(DFP_VERSION)"
endif
ifeq ($(MULTI_GAME_MODE),yes)
	@echo "Build mode: Multi-game ($(GAME_REGISTRY) detected)"
else
	@echo "Build mode: Single-game ($(STORY_FILE))"
endif

# Create necessary directories
directories:
	@mkdir -p $(OBJ_DIR)/$(SRC_DIR)
	@mkdir -p $(OBJ_DIR)/startup
	@mkdir -p $(OBJ_DIR)/zvibe/core
	@mkdir -p $(OBJ_DIR)/zvibe/api
	@mkdir -p $(BIN_DIR)

# Story data generation - single game mode
story_data: $(SRC_DIR)/story_data.c

$(SRC_DIR)/story_data.c: $(STORY_FILE) tools/z3_to_c_array.py
	@echo "Converting story file $(STORY_FILE) to C array..."
	python3 tools/z3_to_c_array.py --single-game $(STORY_FILE) $(SRC_DIR)/story_data.c

# Multi-game data generation
# Note: Multi-game files must be generated externally using the unified build system:
#   cd ../../tools && ./build_games.py same51
# This target is kept for compatibility but does not auto-generate files
multi_game_data: $(SRC_DIR)/game_registry.c build_game_objects

$(SRC_DIR)/game_registry.c:
	@echo "ERROR: Multi-game files not found!"
	@echo "Please run the unified build system first:"
	@echo "  cd ../../tools && ./build_games.py same51"
	@exit 1

# Build game data objects (after data files are generated)
build_game_objects: $(SRC_DIR)/game_registry.c
	@echo "Building game data objects..."
	@for file in $(shell find $(SRC_DIR) -name "*_data.c" 2>/dev/null); do \
		obj_file="$(OBJ_DIR)/$${file%.c}.o"; \
		dep_file="$(OBJ_DIR)/$${file%.c}.d"; \
		echo "Compiling $$file -> $$obj_file"; \
		$(CC) $(CFLAGS) -MF"$$dep_file" -o "$$obj_file" "$$file"; \
	done

# Compile rules for local files
$(OBJ_DIR)/%.o: %.c | directories
	$(CC) $(CFLAGS) -MF"$(@:.o=.d)" -o "$@" "$<"

# Compile rules for zvibe core files
$(OBJ_DIR)/zvibe/%.o: $(ZVIBE_CORE_DIR)/%.c | directories
	$(CC) $(CFLAGS) -MF"$(@:.o=.d)" -o "$@" "$<"

# Link to create ELF
ifeq ($(MULTI_GAME_MODE),yes)
$(BIN_DIR)/$(PROJECT_NAME).elf: $(OBJECTS) build_game_objects
	@echo "Linking multi-game executable..."
	$(CC) $(LDFLAGS) -o "$@" $(OBJECTS) $(shell find $(OBJ_DIR)/$(SRC_DIR) -name "*_data.o" 2>/dev/null)
else
$(BIN_DIR)/$(PROJECT_NAME).elf: $(OBJECTS)
	$(CC) $(LDFLAGS) -o "$@" $(OBJECTS)
endif

# Create binary file
# macOS: xc32-objcopy -O binary expands BSS to 512 MB with XC32 v5.0 due to ALLOC-only
#        sections at 0x20000000; use xc32-bin2hex instead, then convert to flat binary.
# Linux: xc32-objcopy -O binary works correctly.
$(TARGET): $(BIN_DIR)/$(PROJECT_NAME).elf
ifeq ($(UNAME_S),Darwin)
	$(XC32_PATH)/xc32-bin2hex "$(BIN_DIR)/$(PROJECT_NAME).elf"
	python3 tools/hex_to_bin.py "$(BIN_DIR)/$(PROJECT_NAME).hex" "$@"
else
	$(OBJCOPY) -O binary --remove-section=.config* "$<" "$@"
endif
	$(SIZE) "$<"
	@echo ""
	@echo "Analyzing memory usage..."
	@./tools/memory_usage.sh "$<" || echo "Memory analysis failed"

# Program target (edbg, same on macOS and Linux)
program: $(TARGET)
	$(PROGRAMMER) "$<"

# Clean target - removes both single-game and multi-game generated files
clean:
	rm -rf $(BUILD_DIR)
	rm -f $(SRC_DIR)/game_registry.c $(SRC_DIR)/*_data.c $(SRC_DIR)/story_data.c

# Help target
help:
	@echo "SAM E51 zvibe Z-Machine Production Build"
	@echo "========================================"
	@echo "Cross-platform build with SmartEEPROM save/restore"
	@echo "Auto-detects macOS/Linux for XC32 toolchain paths"
	@echo ""
ifeq ($(MULTI_GAME_MODE),yes)
	@echo "Current mode: MULTI-GAME ($(GAME_REGISTRY) detected)"
	@echo "Available targets:"
	@echo "  all              - Build multi-game project (default)"
	@echo "  multi_game_data  - Convert all games to C arrays and generate registry"
	@echo "  program          - Program the device using edbg"
	@echo "  clean            - Remove all build files and generated game data"
	@echo "  help             - Show this help message"
else
	@echo "Current mode: SINGLE-GAME"
	@echo "Available targets:"
	@echo "  all         - Build single-game project (default)"
	@echo "  story_data  - Convert story file to C array"
	@echo "  program     - Program the device using edbg"
	@echo "  clean       - Remove all build files and story data"
	@echo "  help        - Show this help message"
endif
	@echo ""
	@echo "Features:"
	@echo "  - Automatic SmartEEPROM fuse configuration for 16KB operation"
	@echo "  - Persistent save/restore across power cycles"
ifeq ($(MULTI_GAME_MODE),yes)
	@echo "  - Multi-game menu system with UART interface"
	@echo "  - Button returns to game selection menu"
endif
	@echo "  - Clean directory structure with build artifacts in build/"
	@echo "  - Optimized for production use"
	@echo ""
	@echo "Build structure:"
	@echo "  Source files: src/"
	@echo "  Object files: build/obj/"
	@echo "  Binaries:     build/bin/"
ifeq ($(MULTI_GAME_MODE),yes)
	@echo ""
	@echo "Multi-game setup (unified build system):"
	@echo "  To add/update games:  cd ../../games && ./get_games.py browse"
	@echo "  To rebuild registry:  cd ../../tools && ./build_games.py same51"
	@echo "  To disable multi-game: make clean  (removes $(GAME_REGISTRY))"
endif

# Include dependency files
-include $(LOCAL_OBJECTS:.o=.d)
-include $(ZVIBE_OBJECTS:.o=.d)

.PHONY: all platform_info directories clean program help story_data
